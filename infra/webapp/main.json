    },
    "githubTokenForScan": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "GitHub token for scanning private repos"
      }
    },
    "containerStartupStrategy": {
      "type": "string",
      "defaultValue": "keep-warm",
      "allowedValues": [
        "scale-to-zero",
        "keep-warm"
      ],
      "metadata": {
        "description": "Container startup strategy"
      }
    },
    "customDomain": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Custom domain (optional, leave empty to skip)"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags for all resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-logs', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "condition": "[parameters('enableAppInsights')]",
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[format('{0}-insights', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix')))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix')))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}-env', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix'))), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix'))), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-logs', parameters('namePrefix')))]"
      ]
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', ''))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true,
        "allowBlobPublicAccess": false
      }
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', '')), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', '')))]"
      ]
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', '')), 'default', 'reports')]",
      "properties": {
        "shareQuota": 1
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', '')), 'default')]"
      ]
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[replace(format('{0}webapp', parameters('namePrefix')), '-', '')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": true
      }
    },
    {
      "condition": "[parameters('enableSharing')]",
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/{1}', format('{0}-env', parameters('namePrefix')), 'reportsshare')]",
      "properties": {
        "azureFile": {
          "accountName": "[toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', ''))]",
          "accountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', ''))), '2023-05-01').keys[0].value]",
          "shareName": "reports",
          "accessMode": "ReadWrite"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env', parameters('namePrefix')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', toLower(replace(format('{0}st{1}', parameters('namePrefix'), uniqueString(resourceGroup().id)), '-', '')))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}-webapp', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env', parameters('namePrefix')))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 3000,
            "transport": "http",
            "allowInsecure": false,
            "customDomains": "[if(not(empty(parameters('customDomain'))), createArray(createObject('name', parameters('customDomain'), 'bindingType', 'SniEnabled')), createArray())]"
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', replace(format('{0}webapp', parameters('namePrefix')), '-', '')), '2023-07-01').loginServer]",
              "username": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', replace(format('{0}webapp', parameters('namePrefix')), '-', '')), '2023-07-01').username]",
              "passwordSecretRef": "acr-password"
            }
          ],
          "secrets": "[concat(createArray(createObject('name', 'acr-password', 'value', listCredentials(resourceId('Microsoft.ContainerRegistry/registries', replace(format('{0}webapp', parameters('namePrefix')), '-', '')), '2023-07-01').passwords[0].value)), if(not(empty(parameters('githubTokenForScan'))), createArray(createObject('name', 'gh-token-for-scan', 'value', parameters('githubTokenForScan'))), createArray()), if(parameters('enableAppInsights'), createArray(createObject('name', 'app-insights-connection-string', 'value', reference(resourceId('Microsoft.Insights/components', format('{0}-insights', parameters('namePrefix'))), '2020-02-02').ConnectionString)), createArray()))]"
        },
        "template": {
          "containers": [
            {
              "name": "webapp",
              "image": "[format('{0}/agentrc-webapp:{1}', reference(resourceId('Microsoft.ContainerRegistry/registries', replace(format('{0}webapp', parameters('namePrefix')), '-', '')), '2023-07-01').loginServer, parameters('containerImageTag'))]",
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "env": "[concat(createArray(createObject('name', 'NODE_ENV', 'value', 'production'), createObject('name', 'PORT', 'value', '3000'), createObject('name', 'ENABLE_SHARING', 'value', if(parameters('enableSharing'), 'true', 'false')), createObject('name', 'REPORTS_DIR', 'value', if(parameters('enableSharing'), '/app/data/reports', ':memory:'))), if(not(empty(parameters('githubTokenForScan'))), createArray(createObject('name', 'GH_TOKEN_FOR_SCAN', 'secretRef', 'gh-token-for-scan')), createArray()), if(parameters('enableAppInsights'), createArray(createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'secretRef', 'app-insights-connection-string')), createArray()))]",
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/api/health",
                    "port": 3000
                  },
                  "periodSeconds": 30,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/api/health",
                    "port": 3000
                  },
                  "periodSeconds": 10,
                  "failureThreshold": 3
                }
              ],
              "volumeMounts": "[if(parameters('enableSharing'), createArray(createObject('volumeName', 'reportsdata', 'mountPath', '/app/data')), createArray())]"
            }
          ],
          "volumes": "[if(parameters('enableSharing'), createArray(createObject('name', 'reportsdata', 'storageName', 'reportsshare', 'storageType', 'AzureFile')), createArray())]",
          "scale": {
            "minReplicas": "[if(equals(parameters('containerStartupStrategy'), 'keep-warm'), 1, 0)]",
            "maxReplicas": 4,
            "rules": [
              {
                "name": "http-rule",
                "http": {
                  "metadata": {
                    "concurrentRequests": "20"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', replace(format('{0}webapp', parameters('namePrefix')), '-', ''))]",
        "[resourceId('Microsoft.Insights/components', format('{0}-insights', parameters('namePrefix')))]",
        "[resourceId('Microsoft.App/managedEnvironments', format('{0}-env', parameters('namePrefix')))]",
        "[resourceId('Microsoft.App/managedEnvironments/storages', format('{0}-env', parameters('namePrefix')), 'reportsshare')]"
      ]
    }
  ],
  "outputs": {
    "appFqdn": {
      "type": "string",
      "metadata": {
        "description": "Container App FQDN"
      },
      "value": "[reference(resourceId('Microsoft.App/containerApps', format('{0}-webapp', parameters('namePrefix'))), '2024-03-01').configuration.ingress.fqdn]"
    },
    "appUrl": {
      "type": "string",
      "metadata": {
        "description": "Container App URL"
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-webapp', parameters('namePrefix'))), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "acrLoginServer": {
      "type": "string",
      "metadata": {
        "description": "ACR login server"
      },
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', replace(format('{0}webapp', parameters('namePrefix')), '-', '')), '2023-07-01').loginServer]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "metadata": {
